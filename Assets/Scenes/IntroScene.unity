  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  textComponent: {fileID: 989620674}
  lines:
  - "Good evening Agent Benno, we\u2019ve received top secret intelligence that a
    mole within our agency is planning on stealing the royal crown tonight."
  - We have been unable to diffuse the situation so we are now in a crisis and we
    need you, our most trustworthy agent to save the day.
  - Your mission is to sneak through Rosenborg Castle and secure the royal crown
    before the mole gets to it first.
  - The future of Denmark is in your hands.
  textSpeed: 0.015
